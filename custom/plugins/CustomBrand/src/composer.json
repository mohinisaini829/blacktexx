{
    "name": "custom/brand",
    "description": "Custom Brand Plugin for Shopware 6",
    "type": "shopware-platform-plugin",
    "version": "1.0.0",
    "autoload": {
        "psr-4": {
            "CustomBrand\\": "src/"
        }
    },
    "extra": {
        "shopware-plugin-class": "CustomBrand\\CustomBrand",
        "label": {
            "de-DE": "Custom Brand",
            "en-GB": "Custom Brand"
        },
        "shopware": {
            "administration": {
                "main": "src/Resources/app/administration/src/module/custom-brand/index.js",
                "style": "src/Resources/app/administration/src/module/custom-brand/style.css"  // Optional: Add if needed
            }
        }
    }
}
