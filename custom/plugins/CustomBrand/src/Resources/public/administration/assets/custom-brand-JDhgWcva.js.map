{# filepath: custom/plugins/CustomBrand/src/Resources/app/administration/src/module/brand-data/page/brand-data.html.twig #}
<div>
    <h1>Brand Data</h1>
    <sw-card>
        <form @submit.prevent="saveForm">
            <sw-field label="Dropdown" required>
                <select v-model="dropdownValue" class="sw-field__input">
                    <option value="">Select...</option>
                    <option value="B & C">B & C</option>
                    <option value="Harko">Harko</option>
                </select>
            </sw-field>

            <sw-field label="Text Field 1" required>
                <input type="text" v-model="text1" class="sw-field__input" required />
            </sw-field>

            <sw-field label="Text Field 2" required>
                <input type="text" v-model="text2" class="sw-field__input" required />
            </sw-field>

            <sw-media-field
                label="Image/PDF"
                :value="mediaId"
                @media-upload="onMediaSelected"
                @media-remove="onMediaSelected(null)"
                fileAccept="image/*,application/pdf"
            />
            
            <sw-button variant="primary" :loading="isLoading" type="submit">Save</sw-button>
        </form>
        <div v-if="success" class="sw-alert sw-alert--success">Saved successfully!</div>
        <div v-if="error" class="sw-alert sw-alert--error">Error saving data.</div>
    </sw-card>
</div>