            <!-- Debug: Set manufacturerId manually to test watcher -->
            <div style="margin: 10px 0;">
                <sw-button @click="brand.manufacturerId = 'testid'">Set manufacturerId to 'testid'</sw-button>
                <span style="color: #888; font-size: 12px;">(Click to test watcher)</span>
            </div>
{% block sw_brand_detail %}
<sw-page class="sw-brand-detail">
    {% block sw_brand_detail_smart_bar_header %}
    <template #smart-bar-header>
        <h2>
            <span v-if="isNewBrand">New Brand</span>
            <span v-else>
                {{ brand && brand.manufacturer ? brand.manufacturer.name : '' }}
            </span>
        </h2>
    </template>
    {% endblock %}

    {% block sw_brand_detail_smart_bar_actions %}
    <template #smart-bar-actions>
        <sw-button @click="onCancel">
            Cancel
        </sw-button>

        <sw-button
            variant="primary"
            :isLoading="isLoading"
            :disabled="isLoading || !brand"
            @click="saveBrand">
            Save
        </sw-button>
    </template>
    {% endblock %}

    {% block sw_brand_detail_content %}
    <template #content>
        <sw-card v-if="brand" title="General Information">
            <sw-single-select
                v-model:value="brand.manufacturerId"
                :options="manufacturerOptions"
                label-property="label"
                value-property="value"
                label="Manufacturer"
                placeholder="Select manufacturer"
                required
                @update:value="onManufacturerInput"
            />

            <!-- Debug: Show and edit manufacturerId directly -->
            <!-- <div style="margin: 10px 0;">
                <label>Debug manufacturerId: </label>
                <input type="text" v-model="brand.manufacturerId" style="width: 200px;" />
                <span style="color: #888; font-size: 12px;">(Change dropdown or edit here to test reactivity)</span>
            </div> -->

            <sw-textarea-field
                v-model="brand.description"
                label="Description"
                placeholder="Enter brand description">
            </sw-textarea-field>

            <sw-switch-field
                v-model="brand.active"
                label="Active">
            </sw-switch-field>

            <sw-number-field
                v-model="brand.displayOrder"
                label="Display Order"
                numberType="int">
            </sw-number-field>
        </sw-card>

        <sw-card v-if="brand" title="Files">
            <div class="sw-field">
                <label>Size Chart</label>
                <input
                    type="file"
                    ref="sizeChartInput"
                    accept=".pdf,.jpg,.jpeg,.png,.gif"
                    @change="onSizeChartFileUpload"
                    style="display: none;" />
                <sw-button @click="$refs.sizeChartInput.click()">
                    Upload Size Chart
                </sw-button>
                <div v-if="brand.sizeChartPath" style="margin-top: 10px;">
                    Current: <a :href="brand.sizeChartPath" target="_blank">{{ brand.sizeChartPath }}</a>
                </div>
            </div>

            <!-- <div class="sw-field" style="margin-top: 20px;">
                <label>Catalog PDF</label>
                <input
                    type="file"
                    ref="catalogInput"
                    accept=".pdf,.jpg,.jpeg,.png,.gif"
                    @change="onCatalogFileUpload"
                    style="display: none;" />
                <sw-button @click="$refs.catalogInput.click()">
                    Upload Catalog
                </sw-button>
                <div v-if="brand.catalogPdfPath" style="margin-top: 10px;">
                    Current: <a :href="brand.catalogPdfPath" target="_blank">{{ brand.catalogPdfPath }}</a>
                </div>
            </div> -->
            <sw-textarea-field
                v-model="brand.catalogPdfPath"
                label="Catalog PDF HTML"
                placeholder="Enter HTML code for catalog PDF link"
                style="margin-top: 20px;">
            </sw-textarea-field>
        </sw-card>

        <sw-card v-if="brand" title="Video Slider HTML">
            <sw-textarea-field
                v-model="brand.videoSliderHtml"
                label="HTML Code"
                placeholder="Paste HTML code here">
            </sw-textarea-field>
        </sw-card>
    </template>
    {% endblock %}
</sw-page>
{% endblock %}
