          "en-GB": "https://store.shopware.com/en/bluewolf.html"
      },
      "supportLink": {
          "de-DE": "https://www.bluewolf-produktion.de/plugin-support.html",
          "en-GB": "https://www.bluewolf-produktion.de/plugin-support.html"
      }
  }
}
