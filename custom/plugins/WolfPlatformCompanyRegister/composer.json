{
  "name": "wolf/wolf-platform-company-register",
  "description": "SW6 nur Firmenanmeldungen",
  "type": "shopware-platform-plugin",
    "version": "v1.6.0",
    "license": "proprietary",
    "require": {
        "shopware/core": ">=6.6.6"
    },
    "authors": [
        {
            "name": "BlueWolf"
        }
    ],

  "autoload": {
    "psr-4": {
      "Wolf\\WolfPlatformCompanyRegister\\": "src/"
    }
  },
  "extra": {
    "shopware-plugin-class": "Wolf\\WolfPlatformCompanyRegister\\WolfPlatformCompanyRegister",
    "label": {
      "de-DE": "Nur Firmenanmeldungen",
      "en-GB": "Company register only"
