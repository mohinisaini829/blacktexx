{% block sw_block_field %}
    <div :class="{ 'has-warning': hasWarning, 'sas-textarea-field': true }">
        {% parent() %}
        {% block sas_textarea_field_max_length %}
        <div
            v-if="maxLength"
            class="sas-text-field-counter-wrapper"
        >
            <span
                v-show="hasWarning"
                class="char-left-count"
            >
                {{ $tc('sas-blog.detail.warning.maxTextCountReached', 0, { charLeft }) }}
            </span>
            <span class="counter">
                <span class="current-counter">{{ currentLength }}</span>
                /
                {{ maxLength }}
            </span>
        </div>
        {% endblock %}
    </div>
{% endblock %}