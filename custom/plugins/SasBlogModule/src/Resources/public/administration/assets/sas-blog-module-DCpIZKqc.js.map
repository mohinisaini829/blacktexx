<sw-modal
    v-if="show"
    :title="$tc('sas-blog.detail.productAssignment.label')"
    class="sas-cms-product-assignment-modal"
    @modal-close="$emit('modal-close')"
>
    <div class="sw-product-blog-assignment">
        <!-- eslint-disable-next-line sw-deprecation-rules/no-twigjs-blocks -->
        {% block sw_product_blog_assignment_container %}
        <div class="sw-product-blog-assignment__select-container">
            <!-- eslint-disable-next-line sw-deprecation-rules/no-twigjs-blocks -->
            {% block sw_product_blog_assignment_select %}
            <sw-entity-single-select
                :label="$tc('sas-blog.detail.productAssignment.label')"
                entity="product"
                value
                :criteria="searchCriteria"
                :context="searchContext"
                disable-auto-close
                show-clearable-button
                @update:value="onToggleProduct"
            >
                <template #result-item="{ item, index }">
                    <slot
                        name="result-item"
                        v-bind="{ item, index, isSelected }"
                    >
                        <sw-select-result
                            :selected="isSelected(item)"
                            v-bind="{ item, index }"
                        >
                            <!-- eslint-disable-next-line sw-deprecation-rules/no-twigjs-blocks -->
                            {% block sw_entity_single_select_base_results_list_result_label %}
                            <span class="sw-select-result__result-item-text">
                                <sw-product-variant-info :variations="item.variation">
                                    {{ item.translated.name || item.name }}
                                </sw-product-variant-info>
                            </span>
                            {% endblock %}
                        </sw-select-result>
                    </slot>
                </template>
            </sw-entity-single-select>
            {% endblock %}
            <!-- eslint-disable-next-line sw-deprecation-rules/no-twigjs-blocks -->
            {% block sw_product_blog_assignment_option_grid %}
            <sw-data-grid
                v-if="total"
                :key="isLoadingGrid"
                :data-source="assignedProducts"
                :is-loading="isLoadingGrid"
                :columns="assignedProductColumns"
                :show-settings="true"
                :show-selection="false"
            >
                <template #actions="{ item }">
                    <sw-context-menu-item
                        variant="danger"
                        @click="removeItem(item)"
                    >
                        {{ $tc('global.default.delete') }}
                    </sw-context-menu-item>
                </template>

                <template #column-product.translated.name="{ item }">
                    <!-- eslint-disable-next-line sw-deprecation-rules/no-twigjs-blocks -->
                    {% block sw_data_grid_columns_render_value %}
                    <span>
                        <sw-product-variant-info :variations="item.variation">
                            {{ item.translated.name || item.name || variantNames[item.id] }}
                        </sw-product-variant-info>
                    </span>
                    {% endblock %}
                </template>
                <!-- eslint-disable-next-line sw-deprecation-rules/no-twigjs-blocks -->
                {% block sw_product_blog_assignment_option_grid_column_position %}
                <template #column-position="{ item }">
                    <sw-data-grid-column-position
                        ref="columnPosition"
                        v-model:value="assignedProducts"
                        :show-value="true"
                        :item="item"
                    />
                </template>
                {% endblock %}
            </sw-data-grid>
            {% endblock %}
            <!-- eslint-disable-next-line sw-deprecation-rules/no-twigjs-blocks -->
            {% block sw_product_blog_assignment_empty_state %}
            <sw-empty-state
                v-if="!total && !isLoadingGrid"
                class="sw-product-blog-assignment__option-list-empty-state"
                title
                :absolute="false"
                :subline="$tc('sas-blog.detail.productAssignment.assignEmptyStateDescription')"
            >
                <template #icon>
                    <img
                        :src="assetFilter('/administration/static/img/empty-states/products-empty-state.svg')"
                        alt="Empty state"
                    >
                </template>
            </sw-empty-state>
            {% endblock %}
        </div>
        {% endblock %}
    </div>
    <template #modal-footer>
        <mt-button
            size="small"
            @click="$emit('modal-close')"
        >
            {{ $tc('global.default.cancel') }}
        </mt-button>
        <mt-button
            variant="primary"
            size="small"
            @click="onSave"
        >
            {{ $tc('global.default.save') }}
        </mt-button>
    </template>
</sw-modal>
