{% block sw_cms_section_content_block_slot %}
    <!-- eslint-disable vue/valid-v-slot -->
    <template
        v-for="el in block.slots"
        :key="el.id"
        #[el.slot]
    >
        <sw-cms-slot
            :element="el"
            :disabled="disabled"
            :active="selectedBlock !== null && selectedBlock.id === block.id"
        />
    </template>
{% endblock %}
