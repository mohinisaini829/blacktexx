{% block element_blog_slider %}
    {% if not sliderConfig %}
        {% set sliderConfig = element.fieldConfig.elements %}
    {% endif %}

    {% set entires = element.isRandom ? element.data.blogEntries.elements|sort((a,b) => random(-1,1)) : element.data.blogEntries.elements %}

    {% if entires %}
        <div
            class="cms-element-{{ element.type }}{% if sliderConfig.displayMode.value == "standard" and sliderConfig.verticalAlign.value %} has-vertical-alignment{% endif %}">
            {% block element_blog_slider_alignment %}
                {% if config.verticalAlign.value %}
                    <div class="cms-element-alignment{% if sliderConfig.verticalAlign.value == "center" %} align-self-center{% elseif sliderConfig.verticalAlign.value == "flex-end" %} align-self-end{% else %} align-self-start{% endif %}">
                {% endif %}

                {% set blogSliderOptions = {
                    blogboxMinWidth: sliderConfig.elMinWidth.value ? sliderConfig.elMinWidth.value : '',
                    slider: {
                        gutter: 30,
                        autoplayButtonOutput: false,
                        nav: false,
                        mouseDrag: sliderConfig.navigation.value ? false : true,
                        controls: sliderConfig.navigation.value ? true : false,
                        autoplay: sliderConfig.rotate.value ? true : false
                    }
                } %}

                {% block element_blog_slider_slider %}
                    {% block element_blog_slider_title %}
                        {% if sliderConfig.title.value %}
                            <div class="cms-element-title">
                                <p class="cms-element-title-paragraph">{{ sliderConfig.title.value }}</p>
                            </div>
                        {% endif %}
                    {% endblock %}

                    {% block element_blog_slider_content %}
                    <div
                        class="base-slider blog-slider{% if sliderConfig.border.value %} has-border{% endif %}{% if sliderConfig.navigation.value %} has-nav{% endif %}"
                        data-blog-slider="true"
                        data-blog-slider-options="{{ blogSliderOptions|json_encode }}">

                        {% block element_blog_slider_inner %}
                            {% block element_blog_slider_element %}
                                <div class="blog-slider-container"
                                     data-blog-slider-container="true">
                                    {% for blog in entires %}
                                        {% block element_blog_slider_inner_item %}
                                            <div class="blog-slider-item">
                                                {% sw_include '@Storefront/storefront/component/blog/card/slider-box.html.twig' with {
                                                    'layout': sliderConfig.boxLayout.value,
                                                    'displayMode': sliderConfig.displayMode.value
                                                } %}
                                            </div>
                                        {% endblock %}
                                    {% endfor %}
                                </div>
                            {% endblock %}

                            {% block element_blog_slider_controls %}
                                {% if sliderConfig.navigation.value %}
                                    <div class="blog-slider-controls-container">
                                        <div class="base-slider-controls"
                                             data-blog-slider-controls="true">
                                            {% block element_blog_slider_controls_items %}
                                                <button
                                                    class="base-slider-controls-prev blog-slider-controls-prev{% if sliderConfig.border.value %} has-border{% endif %}">
                                                    {% block element_blog_slider_controls_items_prev_icon %}
                                                        {% sw_icon 'arrow-head-left' %}
                                                    {% endblock %}
                                                </button>
                                                <button
                                                    class="base-slider-controls-next blog-slider-controls-next{% if sliderConfig.border.value %} has-border{% endif %}">
                                                    {% block element_blog_slider_controls_items_next_icon %}
                                                        {% sw_icon 'arrow-head-right' %}
                                                    {% endblock %}
                                                </button>
                                            {% endblock %}
                                        </div>
                                    </div>
                                {% endif %}
                            {% endblock %}
                        {% endblock %}
                    </div>
                    {% endblock %}
                {% endblock %}
                {% if config.verticalAlign.value %}
                    </div>
                {% endif %}
            {% endblock %}
        </div>
    {% endif %}
{% endblock %}
