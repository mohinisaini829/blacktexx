{% sw_extends '@Storefront/storefront/layout/meta.html.twig' %}

{% set entry = page.blogEntry %}

{% if activeRoute == 'sas.frontend.blog.detail' and entry.media.url %}
    {% set metaImage = entry.media.url|striptags|trim %}
{% endif %}


{% block layout_head_meta_tags_image_og %}{{ metaImage ?? parent() }}{% endblock %}
{% block layout_head_meta_tags_image_twitter %}{{ metaImage ?? parent() }}{% endblock %}
{% block layout_head_meta_tags_image_meta %}{{ metaImage ?? parent() }}{% endblock %}

{% block layout_head_canonical %}
    {% set entry = page.blogEntry %}

    {% if activeRoute == 'sas.frontend.blog.detail' %}
        {% set blogUrl = page.metaInformation.canonical ? page.metaInformation.canonical : seoUrl('sas.frontend.blog.detail', { articleId: entry.id }) %}
        <link rel="canonical" href="{{ blogUrl }}">
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block layout_head_meta_tags_schema_webpage %}
    {{ parent() }}

    {% block blog_layout_head_meta_tags_schema_webpage %}
        {% if activeRoute == 'sas.frontend.blog.detail' %}
            {% set blogUrl = page.metaInformation.canonical ? page.metaInformation.canonical : seoUrl('sas.frontend.blog.detail', { articleId: entry.id }) %}
            <script type="application/ld+json">
                {
                    "@context": "https://schema.org",
                    "@type": "BlogPosting",
                    "headline": "{{ entry.translated.title }}",
                    "datePublished": "{{ entry.publishedAt|date('Y-m-d\\TH:i:sP') }}",
                    "dateModified": "{{ (entry.updatedAt ?? entry.createdAt)|date('Y-m-d\\TH:i:sP') }}",
                    "author": [
                        {
                            "@type": "Person",
                            "name": "{{ entry.blogAuthor.displayName ?? entry.blogAuthor.translated.name }}",
                            "url": "{{ blogUrl }}"
                        },
                        {
                            "@type": "Organization",
                            "name": "{{ basicConfig.shopName }}",
                            "url": "{{ blogUrl }}"
                        }
                    ],
                    {% if entry.media.thumbnails.elements|length %}
                    "image":[
                        {% for item in entry.media.thumbnails.elements %}
                            "{{ item.url }}" {{ loop.last ? '' : ',' }}
                        {% endfor %}],
                    {% endif %}
                    "publisher": [{
                        "name": "{{ basicConfig.shopName }}",
                        "url": "{{ blogUrl }}"
                    }]
                }
            </script>
        {% endif %}
    {% endblock %}
{% endblock %}
