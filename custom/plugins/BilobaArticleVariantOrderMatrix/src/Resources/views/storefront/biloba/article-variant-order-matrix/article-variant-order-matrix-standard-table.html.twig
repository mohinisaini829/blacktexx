                                                                                    data-bit-variant-id="{{ tmpVariantId }}" 
                                                                                    class="product-detail-configurator-option-image bit-variant-opt-img {% if config("BilobaArticleVariantOrderMatrix.config.layoutStandardChangeImageOnYAxis") %}is-link{% endif %}"
                                                                                    alt="{{ secondGroupOption.translated.name }}"
                                                                                    title="{{ secondGroupOption.translated.name }}" />
                                                                            </div>
                                                                        {% else %}
                                                                            <div class="variant-options text">
                                                                                <label 
                                                                                    {% if config("BilobaArticleVariantOrderMatrix.config.layoutStandardChangeImageOnYAxis") %}data-attribute-change-image="true" data-attribute-change-image-options="{{ imageChangeConfig|json_encode }}"{% endif %} 
                                                                                    data-bit-variant-id="{{ tmpVariantId }}" 
                                                                                    class="product-detail-configurator-option-label is-combinable is-display-media" 
                                                                                    for="{{optionIdentifier}}" title="{{ secondGroupOption.translated.name }}">{{ secondGroupOption.translated.name }}
                                                                                </label>
                                                                            </div>
                                                                        {% endif %}
                                                                    {% endif %}
                                                                </td>
                                                            {% endblock %}
                                                        {# DisplayType == text #}
                                                        {% else %}
                                                            {% block biloba_variant_matrix_body_not_one_variant_y_orientation_text %}  
                                                                <td scope="col">
                                                                    {% if config("BilobaArticleVariantOrderMatrix.config.useVariantImageOnYAxis") %}
                                                                        <td scope="col">
                                                                            <div class="variant-options media">
                                                                                {% set mediaSrc = (tmpVariantElement.cover.media.thumbnails.elements|first).url %}
                                                                                {% if mediaSrc == null %}
                                                                                    {% set mediaSrc = tmpVariantElement.cover.media.url %}
                                                                                {% endif %}
                                                                                {% if mediaSrc == null %}
                                                                                    {% set media = tmpVariantElement.media.elements|sort((a, b) => a.position <=> b.position) %}
                                                                                    {% set mediaSrc = ((media|first).media.thumbnails.elements|first).url %}
                                                                                {% endif %}
                                                                                {% if mediaSrc == null %}
                                                                                    {% set mediaSrc = (media|first).media.url %}
                                                                                {% endif %}
                                                                                <img 
                                                                                    src="{{ mediaSrc }}"
                                                                                    {% if config("BilobaArticleVariantOrderMatrix.config.layoutStandardChangeImageOnYAxis") %}data-attribute-change-image="true" data-attribute-change-image-options="{{ imageChangeConfig|json_encode }}"{% endif %} 
                                                                                    data-bit-variant-id="{{ tmpVariantId }}" 
                                                                                    class="product-detail-configurator-option-image bit-variant-opt-img {% if config("BilobaArticleVariantOrderMatrix.config.layoutStandardChangeImageOnYAxis") %}is-link{% endif %}"
                                                                                    alt="{{ secondGroupOption.translated.name }}"
                                                                                    title="{{ secondGroupOption.translated.name }}" />
                                                                            </div>
                                                                        </td>
                                                                    {% else %}
                                                                        <div class="variant-options text">
                                                                            <label 
                                                                                {% if config("BilobaArticleVariantOrderMatrix.config.layoutStandardChangeImageOnYAxis") %}data-attribute-change-image="true" data-attribute-change-image-options="{{ imageChangeConfig|json_encode }}"{% endif %} 
                                                                                data-bit-variant-id="{{ tmpVariantId }}" 
                                                                                class="product-detail-configurator-option-label is-combinable is-display-text" 
                                                                            for="{{optionIdentifier}}" title="{{ secondGroupOption.translated.name }}">{{ secondGroupOption.translated.name }}</label>
                                                                        </div>
                                                                    {% endif %}
                                                                </td>
                                                            {% endblock %}
                                                        {% endif %}
                                                    {% endif %}
                                                {% endblock %}
                                            {% endif %}

                                            {% if caseOneVariant  %}
                                                {% set groupOptionId = null %}

                                                {% for optKey, value in variantMatrixArrayKeysAndValues %}
                                                    {% set currentKey = secondGroupOption.id %}

                                                    {% if currentKey == optKey %}
                                                        {% set key =  value %}
                                                        {% set groupOptionId = currentKey %}
                                                    {% endif %}
                                                {% endfor %}

                                                {% if groupOptionId != null %}
                                                    {% set childProduct = children[variantMatrixArrayKeysAndValues[groupOptionId]] %}
                                                    {% set currencyID = context.currency.id %}

                                                    {# include calculatedPrice #}
                                                    {% if context.currentCustomerGroup.id not in config("BilobaArticleVariantOrderMatrix.config.hidePriceForCustomerIds") %}
                                                        <td>
                                                            <div class="variant-options-price text-center">
                                                                {% sw_include "@Storefront/storefront/biloba/article-variant-order-matrix/includes/calculatedPrice.html.twig" with {"childProduct":childProduct} %}
                                                            </div>
                                                        </td>
                                                    {% endif %}

                                                    {% if dropdown %}
                                                        <td>{% sw_include '@Storefront/storefront/biloba/article-variant-order-matrix/article-variant-order-matrix-dropdown-list.html.twig' with {'currentKey': currentKey, 'childProduct': childProduct, 'key': key} %}</td>
                                                    {% else %}
                                                        <td>{% sw_include '@Storefront/storefront/biloba/article-variant-order-matrix/article-variant-order-matrix-input-fields.html.twig' with {'currentKey': currentKey, 'childProduct': childProduct, 'key': key} %}</td>
                                                    {% endif %}
                                                {% endif %}
                                            {# more then one variant #}
                                            {% else %}
                                                {# include firstGroupOption iteration for option selectors #}
                                                {% sw_include "@Storefront/storefront/biloba/article-variant-order-matrix/includes/defaultLayout/moreThenOneGroupOption/optionSelectors/firstGroupOptionIteration.html.twig" %}
                                            {% endif %}
                                        </tr>
                                    {% endfor %}
                                {# caseOrientY false #}
                                {% else %}
                                    <tr>
                                        <td>{{ 'biloba.ArticleVariantOrderMatrix.VariantOrderMatrixColAmount'|trans }}</td>
                                        {# we have only one variant #}
                                        {% if caseOneVariant %}
                                            {# include firstGroupOption iteration for option selectors #}
                                            {% sw_include "@Storefront/storefront/biloba/article-variant-order-matrix/includes/defaultLayout/oneGroupOption/optionSelectors/firstGroupOptionIteration.html.twig" %}
                                        {% endif %}
                                    </tr>
                                    {% if context.currentCustomerGroup.id not in config("BilobaArticleVariantOrderMatrix.config.hidePriceForCustomerIds") %}
                                        <tr>
                                            <td>{{ 'biloba.ArticleVariantOrderMatrix.UnitPrice'|trans }}</td>

                                            {% set children = page.extensions.bilobaArticleVariantOrderMatrix.elements.children %}
                                            
                                            {# include firstGroupOption iteration for unit price #}
                                            {% sw_include "@Storefront/storefront/biloba/article-variant-order-matrix/includes/defaultLayout/oneGroupOption/calculatedPrice/firstGroupOptionIteration.html.twig" %}
                                        </tr>
                                    {% endif %}
                                {% endif %}
                            </tbody>
                        {% endblock %}
                    {% endfor %}
                {% endblock %}
            </table>
        </div>
    </div>
{% endblock %}