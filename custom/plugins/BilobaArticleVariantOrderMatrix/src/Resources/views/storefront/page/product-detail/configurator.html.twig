{% sw_extends '@Storefront/storefront/page/product-detail/configurator.html.twig'%}

{% if page.configuratorSettings %}
    {% set configuratorSettings = page.configuratorSettings %}
{% elseif page.product.configurator %}
    {% set configuratorSettings = page.product.configurator %}
{% else %}
    {% set configuratorSettings = page.extensions['bilobaArticleVariantOrderMatrix'].elements['configuratorSettings'] %}
{% endif %}

{% block page_product_detail_configurator_groups %}
    {% if config("BilobaArticleVariantOrderMatrix.config.variantMatrixEnabled") == true 
            and context.currentCustomerGroup.id not in config("BilobaArticleVariantOrderMatrix.config.disableMatrixForCustomersIds")
            and page.extensions.bilobaArticleVariantOrderMatrix.elements.variantMatrixActive == true%}
        {% set lastGroup = false %}

        {% for group in page.configuratorSettings %}
            {% if loop.last %}
                {% set lastGroup = true %}
            {% endif %}

            {% block page_product_detail_configurator_group %}
                {% if page.extensions.bilobaArticleVariantOrderMatrix.elements.showShopwareSelection %}
                    {{ parent() }}
                {% endif %}
                {% if config("BilobaArticleVariantOrderMatrix.config.variantMatrixEnabled") == true 
                        and context.currentCustomerGroup.id not in config("BilobaArticleVariantOrderMatrix.config.disableMatrixForCustomersIds")            
                        and page.extensions.bilobaArticleVariantOrderMatrix.elements.variantMatrixActive == true 
                        and ((page.extensions.bilobaArticleVariantOrderMatrix.elements.variantMatrixLayout == "selector" 
                            and configuratorSettings.elements|length >= 1) or (page.extensions.bilobaArticleVariantOrderMatrix.elements.variantMatrixLayout != "selector")) %}
                    {# display all group options except the last group if layout lastGroupAsMatrixAndOtherGroupsAsSwOptions #}
                    {% if page.extensions.bilobaArticleVariantOrderMatrix.elements.variantMatrixLayout == "lastGroupAsMatrixAndOtherGroupsAsSwOptions" and configuratorSettings.elements|length >= 2 %}
                        {% if not lastGroup %}
                            {{ parent() }}
                        {% endif %}
                    {% endif %}
                {% else %}
                    {{ parent() }}
                {% endif %}
            {% endblock %}
        {% endfor %}
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block page_product_detail_configurator_option_radio %}
    {% if config("BilobaArticleVariantOrderMatrix.config.variantMatrixEnabled") == true
                and context.currentCustomerGroup.id not in config("BilobaArticleVariantOrderMatrix.config.disableMatrixForCustomersIds")
                and page.extensions.bilobaArticleVariantOrderMatrix.elements.variantMatrixActive == true %}
        {# if variant matrix is active always set isCombinableCls #}
        <input type="radio"
                name="{{ group.id }}"
                value="{{ option.id }}"
                class="bit-variant-matrix-is-combinable product-detail-configurator-option-input {{ isCombinableCls }}"
                title="{{ optionIdentifier }}"
                id="{{ optionIdentifier }}"
                {% if isActive %}checked="checked"{% endif %}>

        {% block page_product_detail_configurator_option_radio_label %}
            <label class="bit-variant-matrix-is-combinable product-detail-configurator-option-label{% if isCombinableCls %} {{ isCombinableCls }}{% endif %} is-display-{{ displayType }}"
                    {% if displayType == 'color' and option.colorHexCode %}
                    style="background-color: {{ option.colorHexCode }}"
                    {% endif %}
                    title="{{ option.translated.name }}"
                    for="{{ optionIdentifier }}">

                {% if displayType == 'media' and media %}
                    {% block page_product_detail_configurator_option_radio_label_media %}
                        {{ parent() }}
                    {% endblock %}
                {% elseif displayType == 'text' or
                            (displayType == 'media' and not media) or
                            (displayType == 'color' and not option.colorHexCode) %}
                    {% block page_product_detail_configurator_option_radio_label_text %}
                        {{ parent() }}
                    {% endblock %}
                {% endif %}
            </label>
        {% endblock %}
    {% elseif config("BilobaArticleVariantOrderMatrix.config.variantMatrixEnabled") != true %}
        {{ parent() }}
    {% endif %}
{% endblock %}