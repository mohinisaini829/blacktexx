    "supportLink": {
      "de-DE": "https://www.userlike.com/de/support",
      "en-GB": "https://www.userlike.com/en/support"
    }
  },
  "autoload": {
    "psr-4": {
      "UserlikeUG\\usrlUserlike6\\": "src/"
    }
  }
