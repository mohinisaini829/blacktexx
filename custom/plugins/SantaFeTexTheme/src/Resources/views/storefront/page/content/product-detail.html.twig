{% sw_extends '@Storefront/storefront/page/content/product-detail.html.twig' %}
{% block cms_breadcrumb %}
    <div class="breadcrumb cms-breadcrumb">
        <div class="container">
            {% sw_include '@Storefront/storefront/layout/breadcrumb.html.twig' with {
                context: context,
                category: page.product.seoCategory
            } only %}
        </div>
    </div>
{% endblock %}

{% block page_product_detail_media %}
    <div class="product-detail-media" data-load-more-images>
        {{ parent() }}
        
        {% if page.product.media|length > 5 %}
            <div class="text-center mt-3">
                <button class="btn btn-primary load-more-images-btn">
                    Load More Images
                </button>
            </div>
        {% endif %}
    </div>
{% endblock %}
