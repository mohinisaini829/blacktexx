{% sw_extends '@Storefront/storefront/element/cms-element-image-gallery.html.twig' %}

{% block element_image_gallery %}
    <style>
        /* Mobile slider styles */
        @media (max-width: 767px) {
            .cms-element-image-gallery .gallery-image-container {
                display: flex !important;
                overflow-x: scroll !important;
                scroll-snap-type: x mandatory !important;
                -webkit-overflow-scrolling: touch !important;
                gap: 0px !important;
                padding: 10px 0px !important;
                scrollbar-width: thin !important;
                scroll-behavior: smooth !important;
            }
            
            .cms-element-image-gallery .gallery-image-container::-webkit-scrollbar {
                height: 8px !important;
            }
            
            .cms-element-image-gallery .gallery-image-container::-webkit-scrollbar-track {
                background: #f1f1f1 !important;
                border-radius: 4px !important;
            }
            
            .cms-element-image-gallery .gallery-image-container::-webkit-scrollbar-thumb {
                background: #888 !important;
                border-radius: 4px !important;
            }
            
            .cms-element-image-gallery .gallery-image-container::-webkit-scrollbar-thumb:hover {
                background: #555 !important;
            }
            
            .cms-element-image-gallery .gallery-image-item {
                flex: 0 0 100% !important;
                max-width: 100% !important;
                scroll-snap-align: start !important;
                display: block !important;
            }
            
            .cms-element-image-gallery .gallery-image-item img {
                width: 100% !important;
                height: auto !important;
                border-radius: 0px !important;
            }
            
            .cms-element-image-gallery .gallery-image-hidden {
                display: block !important;
            }
            
            .cms-element-image-gallery .load-more-wrapper {
                display: none !important;
            }
        }
        
        /* Desktop vertical layout - one by one */
        @media (min-width: 768px) {
            .cms-element-image-gallery .gallery-image-container {
                display: flex !important;
                flex-direction: column !important;
                gap: 20px !important;
            }
            
            .cms-element-image-gallery .gallery-image-item {
                width: 100% !important;
                display: block !important;
            }
            
            .cms-element-image-gallery .gallery-image-item img {
                width: 100% !important;
                height: auto !important;
            }
            
            .cms-element-image-gallery .gallery-image-hidden {
                display: none !important;
            }
            
            .cms-element-image-gallery .load-more-wrapper {
                display: block !important;
            }
        }
    </style>
    
    <div class="cms-element-image-gallery">
        <div class="gallery-image-container">
            {% set imagesToShow = 4 %}
            {% for item in element.data.sliderItems %}
                {% if item.media is defined and item.media.url is defined %}
                    <div class="gallery-image-item {% if loop.index > imagesToShow %}gallery-image-hidden{% endif %}">
                        <img src="{{ item.media.url }}"
                             class="img-fluid gallery-image"
                             alt="{{ item.media.alt ?: '' }}"
                             title="{{ item.media.title ?: '' }}" />
                    </div>
                {% endif %}
            {% endfor %}
        </div>
        
        {% if element.data.sliderItems|length > imagesToShow %}
            <div class="load-more-wrapper text-center mt-3">
                <button class="btn btn-primary js-load-more-images" onclick="showAllImages(this); return false;">
                    Load more images
                </button>
            </div>
        {% endif %}
    </div>

    <script>
        function showAllImages(button) {
            var hiddenImages = document.querySelectorAll('.gallery-image-hidden');
            for (var i = 0; i < hiddenImages.length; i++) {
                hiddenImages[i].classList.remove('gallery-image-hidden');
            }
            // Remove the button wrapper completely
            var wrapper = button.closest('.load-more-wrapper');
            if (wrapper) {
                wrapper.remove();
            }
        }

        // Auto-scroll for mobile slider only
        if (window.innerWidth <= 767) {
            document.addEventListener('DOMContentLoaded', function() {
                var galleryContainer = document.querySelector('.cms-element-image-gallery .gallery-image-container');
                if (galleryContainer && galleryContainer.children.length > 1) {
                    var scrollAmount = 0;
                    var scrollInterval;
                    var isPaused = false;
                    
                    function autoScroll() {
                        if (!isPaused) {
                            scrollAmount += galleryContainer.offsetWidth; // full image width
                            
                            if (scrollAmount >= galleryContainer.scrollWidth - galleryContainer.offsetWidth) {
                                scrollAmount = 0; // Reset to start
                            }
                            
                            galleryContainer.scrollTo({
                                left: scrollAmount,
                                behavior: 'smooth'
                            });
                        }
                    }
                    
                    // Start auto-scroll every 3 seconds
                    scrollInterval = setInterval(autoScroll, 3000);
                    
                    // Pause on touch/interaction
                    galleryContainer.addEventListener('touchstart', function() {
                        isPaused = true;
                    });
                    
                    galleryContainer.addEventListener('touchend', function() {
                        setTimeout(function() {
                            isPaused = false;
                        }, 3000); // Resume after 3 seconds
                    });
                    
                    // Pause on scroll
                    galleryContainer.addEventListener('scroll', function() {
                        isPaused = true;
                        clearTimeout(galleryContainer.scrollTimeout);
                        galleryContainer.scrollTimeout = setTimeout(function() {
                            isPaused = false;
                        }, 3000);
                    });
                }
            });
        }
    </script>

    <!-- {{ parent() }} -->
    
{% endblock %}

{% block element_image_gallery_inner %}
    {% set minHeight = '530px' %}

    {% set thumbnailSlider = gallerySliderOptions.thumbnailSlider|merge(
        {
            "items": (galleryPosition == "underneath") ? 3 : 5,
            "slideBy": (galleryPosition == "underneath") ? 3 : 5
        })
    %}
    {% set gallerySliderOptions = gallerySliderOptions|merge({thumbnailSlider}) %}

    {% set slider = gallerySliderOptions.slider|merge(
        {
            "items": 1,
            "slideBy": 1,
            "gutter": 3,
            "responsive": {
                "sm": {
                    "items": 1,
                    "slideBy": 1
                },
                "md": {
                    "items": 2,
                    "slideBy": 2
                },
                "lg": {
                    "items": 2,
                    "slideBy": 2
                },
                "xl": {
                    "items": 2,
                    "slideBy": 2
                },
                "xxl": {
                    "items": 2,
                    "slideBy": 2
                }
            }
        })
    %}
    {% set gallerySliderOptions = gallerySliderOptions|merge({slider}) %}

    {{ parent() }}
    {% if imageCount <= 1 %}
        {% block vio_overlay_buttons %}
            {% if page.product and
                page.product.manufacturer and
                page.product.manufacturer.translated.customFields and
                (page.product.manufacturer.translated.customFields.vio_product_catalog or vio_manufacturer_video_slider)%}
                <div class="image-badges bottom">
                    {% if page.product.manufacturer.translated.customFields.vio_manufacturer_video_slider is not empty %}
                        <a class="btn btn-light"
                           href="#manufacturer-video-slider"
                           title="{{ 'santa-theme.sw-cms.elements.vio-manufacturer-video-slider.title'|trans }}">
                            {% sw_icon 'video-camera' %}
                            {{ 'santa-theme.sw-cms.elements.vio-manufacturer-video-slider.button'|trans }}
                        </a>
                    {% endif %}
                    {% if page.product.manufacturer.translated.customFields.vio_product_catalog is not empty %}
                        <a class="btn btn-light"
                           href="#vio_product_catalog"
                           title="{{ 'santa-theme.sw-cms.elements.vio-manufacturer-catalog.title'|trans }}">
                            {% sw_icon 'file' %}
                            {{ 'santa-theme.sw-cms.elements.vio-manufacturer-catalog.button'|trans }}
                        </a>
                    {% endif %}
                </div>
            {% endif %}
        {% endblock %}
    {% endif %}

{% endblock %}

{% block element_image_gallery_inner_thumbnails_col %}
    {% if imageCount > 2 %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block element_image_gallery_slider_dots %}
    {% if imageCount > 2 %}
        {{ parent() }}
    {% endif %}
{% endblock %}
