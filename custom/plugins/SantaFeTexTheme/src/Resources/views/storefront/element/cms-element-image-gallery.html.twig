{% sw_extends '@Storefront/storefront/element/cms-element-image-gallery.html.twig' %}

{% block element_image_gallery %}
    <style>
        .gallery-image-hidden {
            display: none !important;
        }
        
        /* Mobile Slider Styles */
        @media (max-width: 768px) {
            .gallery-image-container {
                overflow-x: auto;
                display: flex;
                scroll-snap-type: x mandatory;
                -webkit-overflow-scrolling: touch;
                gap: 10px;
                padding: 10px 0;
            }
            
            .gallery-image-item {
                flex: 0 0 85%;
                scroll-snap-align: center;
            }
            
            .gallery-image-container::-webkit-scrollbar {
                height: 6px;
            }
            
            .gallery-image-container::-webkit-scrollbar-track {
                background: #f1f1f1;
                border-radius: 10px;
            }
            
            .gallery-image-container::-webkit-scrollbar-thumb {
                background: #888;
                border-radius: 10px;
            }
            
            .gallery-image-container::-webkit-scrollbar-thumb:hover {
                background: #555;
            }
        }
        
        /* Desktop Grid */
        @media (min-width: 769px) {
            .gallery-image-container {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
                gap: 15px;
            }
        }
    </style>
    
    <div class="cms-element-image-gallery">
        <div class="gallery-image-container">
            {% set imagesToShow = 4 %}
            {% for item in element.data.sliderItems %}
                {% if item.media is defined and item.media.url is defined %}
                    <div class="gallery-image-item {% if loop.index > imagesToShow %}gallery-image-hidden{% endif %}">
                        <img src="{{ item.media.url }}"
                             class="img-fluid gallery-image"
                             alt="{{ item.media.alt ?: '' }}"
                             title="{{ item.media.title ?: '' }}"
                             style="width:100%;height:auto;" />
                    </div>
                {% endif %}
            {% endfor %}
        </div>
        
        {% if element.data.sliderItems|length > imagesToShow %}
            <div class="load-more-wrapper text-center mt-3">
                <button class="btn btn-primary js-load-more-images" onclick="showAllImages(this); return false;">
                    Load more images
                </button>
            </div>
        {% endif %}
    </div>

    <script>
        function showAllImages(button) {
            var hiddenImages = document.querySelectorAll('.gallery-image-hidden');
            
            for (var i = 0; i < hiddenImages.length; i++) {
                hiddenImages[i].classList.remove('gallery-image-hidden');
            }
            
            button.parentElement.style.display = 'none';
        }
    </script>

    <!-- {{ parent() }} -->
    
{% endblock %}

{% block element_image_gallery_inner %}
    {% set minHeight = '530px' %}

    {% set thumbnailSlider = gallerySliderOptions.thumbnailSlider|merge(
        {
            "items": (galleryPosition == "underneath") ? 3 : 5,
            "slideBy": (galleryPosition == "underneath") ? 3 : 5
        })
    %}
    {% set gallerySliderOptions = gallerySliderOptions|merge({thumbnailSlider}) %}

    {% set slider = gallerySliderOptions.slider|merge(
        {
            "items": 1,
            "slideBy": 1,
            "gutter": 3,
            "responsive": {
                "sm": {
                    "items": 1,
                    "slideBy": 1
                },
                "md": {
                    "items": 2,
                    "slideBy": 2
                },
                "lg": {
                    "items": 2,
                    "slideBy": 2
                },
                "xl": {
                    "items": 2,
                    "slideBy": 2
                },
                "xxl": {
                    "items": 2,
                    "slideBy": 2
                }
            }
        })
    %}
    {% set gallerySliderOptions = gallerySliderOptions|merge({slider}) %}

    {{ parent() }}
    {% if imageCount <= 1 %}
        {% block vio_overlay_buttons %}
            {% if page.product and
                page.product.manufacturer and
                page.product.manufacturer.translated.customFields and
                (page.product.manufacturer.translated.customFields.vio_product_catalog or vio_manufacturer_video_slider)%}
                <div class="image-badges bottom">
                    {% if page.product.manufacturer.translated.customFields.vio_manufacturer_video_slider is not empty %}
                        <a class="btn btn-light"
                           href="#manufacturer-video-slider"
                           title="{{ 'santa-theme.sw-cms.elements.vio-manufacturer-video-slider.title'|trans }}">
                            {% sw_icon 'video-camera' %}
                            {{ 'santa-theme.sw-cms.elements.vio-manufacturer-video-slider.button'|trans }}
                        </a>
                    {% endif %}
                    {% if page.product.manufacturer.translated.customFields.vio_product_catalog is not empty %}
                        <a class="btn btn-light"
                           href="#vio_product_catalog"
                           title="{{ 'santa-theme.sw-cms.elements.vio-manufacturer-catalog.title'|trans }}">
                            {% sw_icon 'file' %}
                            {{ 'santa-theme.sw-cms.elements.vio-manufacturer-catalog.button'|trans }}
                        </a>
                    {% endif %}
                </div>
            {% endif %}
        {% endblock %}
    {% endif %}

{% endblock %}

{% block element_image_gallery_inner_thumbnails_col %}
    {% if imageCount > 2 %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block element_image_gallery_slider_dots %}
    {% if imageCount > 2 %}
        {{ parent() }}
    {% endif %}
{% endblock %}
