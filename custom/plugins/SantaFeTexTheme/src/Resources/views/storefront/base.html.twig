    <script>
    $(function() {
        var $sticky = $('#stickyBuybox');
        var $gallery = $('.product-detail-media');
        if ($sticky.length && $gallery.length) {
            var stickyTop = $sticky.offset().top;

            $(window).on('scroll resize', function() {
        //console.log('555555555');
                var scrollTop = $(window).scrollTop();
                var galleryBottom = $gallery.offset().top + $gallery.outerHeight();
                var stickyHeight = $sticky.outerHeight();
                var stickyBottom = scrollTop + stickyHeight;

                if (scrollTop > stickyTop && stickyBottom < galleryBottom) {
                    $sticky.addClass('sticky-buybox');
                } else {
                    $sticky.removeClass('sticky-buybox');
                }
            });
        }

    });
    
</script>
