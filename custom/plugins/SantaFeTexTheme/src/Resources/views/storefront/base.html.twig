  <script>
    $(document).ready(function () {
        function enableAccordionForMobile() {
            if ($(window).width() <= 768) {
                $('.accordion-content').hide(); // hide all initially on mobile

                $('.accordion-header').off('click').on('click', function () {
                    $(this).toggleClass('active');
                    $(this).next('.accordion-content').slideToggle(200);
                });
            } else {
                // Reset on desktop
                $('.accordion-content').show();
                $('.accordion-header').off('click').removeClass('active');
            }
        }

        enableAccordionForMobile();

        $(window).on('resize', function () {
            enableAccordionForMobile();
        });

    });
  </script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
        // Get inquiryId from URL query string
        const urlParams = new URLSearchParams(window.location.search);
        const inquiryId = urlParams.get('inquiryId');

        if (inquiryId) {
            // Prepare the URL for AJAX call
            const ajaxUrl = '/myfav/inquiry/trigger?inquiryId=' + encodeURIComponent(inquiryId);

            fetch(ajaxUrl, {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                console.log('AJAX response:', data);
            })
            .catch(error => {
                console.error('AJAX error:', error);
            });
        }
    });

</script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Get all caret toggle elements
        var caretToggles = document.querySelectorAll('.caret-toggle');

        caretToggles.forEach(function(caret) {
            caret.addEventListener('click', function() {
                // Get the section ID from the data-section attribute
                var sectionId = caret.getAttribute('data-section');
                var section = document.getElementById(sectionId);

                // Toggle the section visibility
                if (section.style.display === 'none' || section.style.display === '') {
                    section.style.display = 'block';
                    caret.classList.remove('collapsed'); // Remove collapsed class
                    caret.classList.add('expanded'); // Add expanded class
                } else {
                    section.style.display = 'none';
                    caret.classList.remove('expanded'); // Remove expanded class
                    caret.classList.add('collapsed'); // Add collapsed class
                }
            });
        });
    });

</script>


