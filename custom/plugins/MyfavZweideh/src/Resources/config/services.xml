<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <!-- Controller -->
        <service id="Myfav\Zweideh\Storefront\Controller\AccountDesignsController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Doctrine\DBAL\Connection" />
            <argument type="service" id="Myfav\Zweideh\Services\ShopwareDesignsService" />
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\AddArticleToVioInquiryController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Doctrine\DBAL\Connection" />
            <argument type="service" id="sales_channel.product.repository"/>
            <argument id="Myfav\Inquiry\Services\InquiryCartService" type="service"/>
        </service>
        
        <service id="Myfav\Zweideh\Storefront\Controller\AddToCartController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\ArticleDataController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="product.repository" />
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\EditorRequestController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="mail_template.repository"/>
            <argument type="service" id="Shopware\Core\Content\Mail\Service\MailService"/>
            <argument type="service" id="myfav.zweideh.logger"/>
            <argument type="service" id="Myfav\Zweideh\Services\DesignRequestService"/>
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\LumiseAdminController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Doctrine\DBAL\Connection" />
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\LumiseDesignerStartController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="product.repository"/>
            <argument type="service" id="shopware.filesystem.public"/>
            <argument type="service" id="Shopware\Core\Content\Media\Core\Application\AbstractMediaUrlGenerator" />
            <argument type="service" id="product_media.repository"/>
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\LumiseDesignImageController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Doctrine\DBAL\Connection" />
            <argument type="service" id="product.repository" />
            <argument type="service" id="event_dispatcher" />
            <argument type="service" id="Shopware\Core\Content\Product\SalesChannel\Detail\ProductDetailRoute" />
            <argument type="service" id="Myfav\Zweideh\Services\ShopwareDesignsService" />
            <argument type="service" id="Symfony\Component\Routing\RouterInterface" />
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\LumiseRequestController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="mail_template.repository"/>
            <argument type="service" id="Shopware\Core\Content\Mail\Service\MailService"/>
            <argument type="service" id="myfav.zweideh.logger"/>
            <argument type="service" id="Myfav\Zweideh\Services\DesignRequestService"/>
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\LumiseRequestImageController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Doctrine\DBAL\Connection" />
            <argument type="service" id="product.repository" />
            <argument type="service" id="event_dispatcher" />
            <argument type="service" id="Shopware\Core\Content\Product\SalesChannel\Detail\ProductDetailRoute" />
            <argument type="service" id="Myfav\Zweideh\Services\DesignRequestService" />
            <argument type="service" id="Symfony\Component\Routing\RouterInterface" />
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\MailPreviewImageController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Doctrine\DBAL\Connection" />
            <argument type="service" id="product.repository" />
            <argument type="service" id="event_dispatcher" />
            <argument type="service" id="Shopware\Core\Content\Product\SalesChannel\Detail\ProductDetailRoute" />
            <argument type="service" id="Myfav\Zweideh\Services\TmpCartService" />
            <argument type="service" id="Symfony\Component\Routing\RouterInterface" />
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\RequestFormController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="mail_template.repository"/>
            <argument type="service" id="Shopware\Core\Content\Mail\Service\MailService"/>
            <argument type="service" id="myfav.zweideh.logger"/>
            <argument type="service" id="Myfav\Zweideh\Services\DesignRequestService"/>
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\SelectSizeController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Doctrine\DBAL\Connection" />
            <argument type="service" id="product.repository" />
            <argument type="service" id="event_dispatcher" />
            <argument type="service" id="Shopware\Core\Content\Product\SalesChannel\Detail\ProductDetailRoute" />
            <argument type="service" id="Myfav\Zweideh\Services\TmpCartService" />
            <argument type="service" id="Symfony\Component\Routing\RouterInterface" />
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\SizeLoaderController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Doctrine\DBAL\Connection" />
            <argument type="service" id="product.repository" />
            <argument type="service" id="sales_channel.product.repository"/>
            <argument type="service" id="cache.object"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="Shopware\Storefront\Page\Product\Configurator\ProductPageConfiguratorLoader"/>
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\TmpCartImageController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Doctrine\DBAL\Connection" />
            <argument type="service" id="product.repository" />
            <argument type="service" id="event_dispatcher" />
            <argument type="service" id="Shopware\Core\Content\Product\SalesChannel\Detail\ProductDetailRoute" />
            <argument type="service" id="Myfav\Zweideh\Services\ShopwareDesignsService" />
            <argument type="service" id="Symfony\Component\Routing\RouterInterface" />
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Myfav\Zweideh\Storefront\Controller\UserSaveDesignController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <argument type="service" id="Doctrine\DBAL\Connection" />
            <argument type="service" id="Myfav\Zweideh\Services\ShopwareDesignsService" />
            <argument type="service" id="Symfony\Component\Routing\Generator\UrlGeneratorInterface" />
        </service>

        <!-- Services -->
        <service id="myfav.zweideh.logger" class="Monolog\Logger">
            <factory service="Psr\Log\LoggerInterface" method="createRotating" />
            <argument type="string">myfav.zweideh</argument>
        </service>

        <service id="Myfav\Zweideh\Services\DesignRequestService">
            <argument type="service" id="Doctrine\DBAL\Connection" />
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Myfav\Zweideh\Services\MyfavZweidehDataLoaderService" public="true">
            <argument type="service" id="Doctrine\DBAL\Connection" />
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="product.repository"/>
        </service>

        <service id="Myfav\Zweideh\Services\ShopwareDesignsService">
            <argument type="service" id="Doctrine\DBAL\Connection" />
        </service>

        <service id="Myfav\Zweideh\Services\TmpCartService">
            <argument type="service" id="Doctrine\DBAL\Connection" />
        </service>

        <!-- Subscriber -->
        <service id="Myfav\Zweideh\Storefront\Subscriber\AccountLoginSubscriber">
            <argument type="service" id="Symfony\Component\HttpFoundation\RequestStack" />
            <tag name="kernel.event_subscriber" />
        </service>
        
        <service id="Myfav\Zweideh\Storefront\Subscriber\ArticleDetailSubscriber">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService" />
            <argument type="service" id="Symfony\Component\HttpFoundation\RequestStack" />
            <tag name="kernel.event_subscriber" />
        </service>

        <service id="Myfav\Zweideh\Storefront\Subscriber\LineItemAddedSubscriber">
            <argument type="service" id="Symfony\Component\HttpFoundation\RequestStack" />
            <tag name="kernel.event_subscriber" />
        </service>
    </services>
</container>
