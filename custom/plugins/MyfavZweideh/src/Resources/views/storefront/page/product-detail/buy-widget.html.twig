{% sw_extends '@SantaFeTexTheme/storefront/page/product-detail/buy-widget.html.twig' %}

{#
IMPORTANT IMPORTANT IMPORTANT IMPORTANT IMPORTANT IMPORTANT IMPORTANT IMPORTANT IMPORTANT

This is the default way to extend a product with our configurator.
But here the bilobaArticleVariantOrderMatrix plugin is used, that overrides the whole buy-widget.
So, if that is active, the functionality instead is overridden in 
Resources/views/storefront/biloba/article-variant-order-matrix/article-variant-order-matrix-button.html.twig.

IMPORTANT IMPORTANT IMPORTANT IMPORTANT IMPORTANT IMPORTANT IMPORTANT IMPORTANT IMPORTANT
#}

{% block page_product_detail_buy_form %}
    {% if page.product.customFields.myfav_zweideh_enabled %}
        <div class="myfav-zweideh-designer-button-container">
            <p class="myfav-zweideh-designer-description">{# {{ 'MyfavZweidehDesignerDescription' | trans }} #} Dieser Artikel ist gestaltbar.</p>
                <a href="{{ path('frontend.home.page') }}{{ config('MyfavZweideh.config.lumisInstallPath') }}editor.php?product_base={{ page.product.customFields.lumis_designer_article_id }}">
                    <button type="button" class="btn btn-primary" id="myfav-obility-designer-button">
                        {#{{ 'MyfavObilityDesignerButtonText' | trans }}#} Hier selbst gestalten
                    </button>
                </a>
            </div>
        </div>
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}