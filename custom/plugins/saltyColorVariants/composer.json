{
    "name": "salty/color-variants",
    "description": "Farb- und Mustervariantenvorschau auf Kategorieseiten",
    "version": "v0.19.0",
    "type": "shopware-platform-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Die Shopwehr"
        }
    ],
    "extra": {
        "shopware-plugin-class": "salty\\ColorVariants\\saltyColorVariants",
        "label": {
            "de-DE": "Farb- und Mustervariantenvorschau auf Kategorieseiten",
            "en-GB": "Color and pattern variants preview on listing pages"
        },
        "description": {
            "de-DE": "Dieses Plugin erweitert die Produktdarstellung auf Kategorieseiten um eine Vorschau bezüglich verfügbarer Farb- und Mustervarianten. ",
            "en-GB": "Color and pattern variants preview on listing pages"
        },
        "manufacturerLink": {
            "de-DE": "https://shopwehr.de",
            "en-GB": "https://shopwehr.de"
        },
        "supportLink": {
            "de-DE": "https://shopwehr.de",
            "en-GB": "https://shopwehr.de"
        }
    },
    "require": {
        "shopware/core": "^6.7.0.0",
        "shopware/administration": "^6.7.0.0",
        "shopware/storefront": "^6.7.0.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^v3.42.0"
    },
    "autoload": {
        "psr-4": {
            "salty\\ColorVariants\\": "src/"
        }
    },
    "scripts": {
        "phpcs": "vendor/bin/php-cs-fixer fix",
        "phpstan": "vendor/bin/phpstan analyse -c phpstan.neon src --autoload-file=vendor/autoload.php"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}
