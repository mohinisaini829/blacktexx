{% block block_netzp_powerpack6_grid3 %}
    {% set columns = 3 %}
    {% set id = element.id %}

    <div class="container-fluid">
        <div class="row">
        {% block block_netzp_powerpack6_grid3_column1 %}
            {% set element = block.slots.getSlot('column1') %}
            <div class="col-sm-12 col-md-2 col-lg-2 mb-3 mb-lg-0" data-cms-element-id="{{ id }}">
                {% block block_netzp_powerpack6_grid3_column1_inner %}
                    {% sw_include "@Storefront/storefront/element/cms-element-" ~ element.type ~ ".html.twig" ignore missing %}
                {% endblock %}
            </div>
        {% endblock %}

        {% block block_netzp_powerpack6_grid3_column2 %}
            {% set element = block.slots.getSlot('column2') %}
            <div class="col-sm-12 col-md-8 col-lg-8 mb-3 mb-lg-0" data-cms-element-id="{{ id }}">
                {% block block_netzp_powerpack6_grid3_column2_inner %}
                    {% sw_include "@Storefront/storefront/element/cms-element-" ~ element.type ~ ".html.twig" ignore missing %}
                {% endblock %}
            </div>
        {% endblock %}

        {% block block_netzp_powerpack6_grid3_column3 %}
            {% set element = block.slots.getSlot('column3') %}
            <div class="col-sm-12 col-md-2 col-lg-2" data-cms-element-id="{{ id }}">
                {% block block_netzp_powerpack6_grid3_column3_inner %}
                    {% sw_include "@Storefront/storefront/element/cms-element-" ~ element.type ~ ".html.twig" ignore missing %}
                {% endblock %}
            </div>
        {% endblock %}
        </div>
    </div>

{% endblock %}
