{% block block_netzp_powerpack6_grid2l %}
    {% set columns = 2 %}
    {% set id = element.id %}

    <div class="container-fluid">
        <div class="row">
        {% block block_netzp_powerpack6_grid2l_column1 %}
            {% set element = block.slots.getSlot('column1') %}
            <div class="col-sm-12 col-md-3 col-lg-3 mb-3 mb-lg-0" data-cms-element-id="{{ id }}">
                {% block block_netzp_powerpack6_grid2l_column1_inner %}
                    {% sw_include "@Storefront/storefront/element/cms-element-" ~ element.type ~ ".html.twig" ignore missing %}
                {% endblock %}
            </div>
        {% endblock %}

        {% block block_netzp_powerpack6_grid2l_column2 %}
            {% set element = block.slots.getSlot('column2') %}
            <div class="col-sm-12 col-md-9 col-lg-9" data-cms-element-id="{{ id }}">
                {% block block_netzp_powerpack6_grid2_column2_inner %}
                    {% sw_include "@Storefront/storefront/element/cms-element-" ~ element.type ~ ".html.twig" ignore missing %}
                {% endblock %}
            </div>
        {% endblock %}
        </div>
    </div>

{% endblock %}
