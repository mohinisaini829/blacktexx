                {% block block_netzp_powerpack6_grid4_column1_inner %}
                    {% sw_include "@Storefront/storefront/element/cms-element-" ~ element.type ~ ".html.twig" ignore missing %}
                {% endblock %}
            </div>
        {% endblock %}

        {% block block_netzp_powerpack6_grid4_column2 %}
            {% set element = block.slots.getSlot('column2') %}
            <div class="col-sm-12 col-md-6 col-lg-3 mb-3 mb-lg-0" data-cms-element-id="{{ id }}">
