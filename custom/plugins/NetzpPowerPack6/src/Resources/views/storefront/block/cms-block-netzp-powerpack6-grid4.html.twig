{% block block_netzp_powerpack6_grid4 %}
    {% set columns = 4 %}
    {% set id = element.id %}

    <div class="container-fluid">
        <div class="row">

        {% block block_netzp_powerpack6_grid4_column1 %}
            {% set element = block.slots.getSlot('column1') %}
