{% block netzp_powerpack6_collapse %}
    <div class="netzp-powerpack6-collapse-element" id="collapse_{{ element.id }}">

        {% block netzp_powerpack6_collapse_title %}
            {% if element.config["title"].value %}
            <h3 class="title">{{ element.config["title"].value }}</h3>
            {% endif %}
        {% endblock %}

        {% for n in range(1, element.config.numberOfItems.value) %}
        <div class="card">
            {% block netzp_powerpack6_collapse_header %}
            <div class="card-header">
                <a class="card-link {% if( not (n==1 and element.config.firstItemOpened.value)) %}collapsed{% endif %}"
                   data-bs-toggle="collapse" href="#item{{ element.id }}_{{ n }}">
                    <strong class="netzp-powerpack6-collapse-header">{{ element.config["itemtitle#{n}"].value|raw }}</strong>
                    <i class="fa float-end" aria-hidden="true"></i>
                </a>
            </div>
            {% endblock %}

            {% block netzp_powerpack6_collapse_item %}
            <div id="item{{ element.id }}_{{ n }}" class="collapse {% if(n==1 and element.config.firstItemOpened.value) %}show{% endif %}"
                 data-bs-parent="#collapse_{{ element.id }}">
                <div class="card-body p-3 netzp-powerpack6-collapse-body">
                    {{ element.config["itemcontents#{n}"].value|raw }}
                </div>
            </div>
            {% endblock %}
        </div>
        {% endfor %}
    </div>
{% endblock %}
