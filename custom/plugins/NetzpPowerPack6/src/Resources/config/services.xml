<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="NetzpPowerPack6\Subscriber\FrontendSubscriber">
            <argument type="service" id="kernel"/>
            <argument type="service" id="twig"/>
            <argument type="service" id="Shopware\Core\Content\Cms\SalesChannel\SalesChannelCmsPageLoader" />
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService" />
            <argument type="service" id="category.repository" />
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="NetzpPowerPack6\Core\Cms\CtaResolver">
            <tag name="shopware.cms.data_resolver"/>
        </service>
        <service id="NetzpPowerPack6\Core\Cms\Cta2Resolver">
            <tag name="shopware.cms.data_resolver"/>
        </service>
        <service id="NetzpPowerPack6\Core\Cms\TestimonialResolver">
            <tag name="shopware.cms.data_resolver"/>
        </service>
        <service id="NetzpPowerPack6\Core\Cms\ParallaxResolver">
            <tag name="shopware.cms.data_resolver"/>
        </service>
        <service id="NetzpPowerPack6\Core\Cms\AlertResolver">
            <tag name="shopware.cms.data_resolver"/>
        </service>
        <service id="NetzpPowerPack6\Core\Cms\ImageCompareResolver">
            <tag name="shopware.cms.data_resolver"/>
        </service>
        <service id="NetzpPowerPack6\Core\Cms\CardResolver">
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="NetzpPowerPack6\Core\Cms\SalesChannelCmsPageLoaderDecorator"
                 decorates="Shopware\Core\Content\Cms\SalesChannel\SalesChannelCmsPageLoader"
                 decoration-priority="80">
            <argument type="service"
                      id="NetzpPowerPack6\Core\Cms\SalesChannelCmsPageLoaderDecorator.inner" />
        </service>
    </services>
</container>
