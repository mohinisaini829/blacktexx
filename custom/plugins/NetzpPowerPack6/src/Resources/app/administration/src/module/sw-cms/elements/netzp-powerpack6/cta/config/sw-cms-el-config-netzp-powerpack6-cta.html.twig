                            <option value="center">
                                {{ $tc('sw-cms.netzp-powerpack6.elements.cta.config.center') }}
                            </option>
                            <option value="right">
                                {{ $tc('sw-cms.netzp-powerpack6.elements.cta.config.right') }}
