                        <sw-text-field :label="$tc('sw-cms.netzp-powerpack6.elements.cta.config.tabs.button.url')"
                                       v-model:value="element.config.buttonUrl.value" />

                        <sw-switch-field bordered :label="$tc('sw-cms.netzp-powerpack6.elements.cta.config.tabs.button.targetblank')"
                                         v-model:value="element.config.buttonTargetBlank.value" />
                    </sw-container>
                </sw-container>

                <sw-container v-if="active === 'layout'">
                    <sw-container columns="1fr 2fr" gap="20px">
