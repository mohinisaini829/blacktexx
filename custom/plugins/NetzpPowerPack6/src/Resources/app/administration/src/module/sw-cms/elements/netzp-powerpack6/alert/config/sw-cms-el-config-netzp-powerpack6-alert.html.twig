{% block sw_cms_element_netzp_powerpack6_alert_config %}
    <div class="sw-cms-el-config-netzp-powerpack6">
        <sw-single-select :label="$t('sw-cms.netzp-powerpack6.elements.alert.config.alertType.label')"
                          :options="optionsAlertType" valueProperty="value"
                          v-model:value="element.config.alertType.value">
            <template #selection-label-property="{ item }">
                {{ item.name }}
            </template>
            <template #result-label-property="{ item }">
                {{ item.name }}
            </template>
        </sw-single-select>

        <sw-cms-mapping-field v-model:config="element.config.title"
                              :label="$tc('sw-cms.netzp-powerpack6.elements.alert.config.title')"
                              value-types="string">
            <sw-text-field v-model:value="element.config.title.value" />

            <template #preview="{ demoValue }">
                <div class="sw-cms-el-config-text__mapping-preview">
                    <div v-html="$sanitize(demoValue)"></div>
                </div>
            </template>
        </sw-cms-mapping-field>

        <sw-cms-mapping-field v-model:config="element.config.contents"
                              :label="$tc('sw-cms.netzp-powerpack6.elements.alert.config.contents')"
                              value-types="string">
            <sw-text-editor :allow-inline-data-mapping="true"
                            v-model:value="element.config.contents.value" />

            <template #preview="{ demoValue }">
                <div class="sw-cms-el-config-text__mapping-preview">
                    <div v-html="$sanitize(demoValue)"></div>
                </div>
            </template>
        </sw-cms-mapping-field>
    </div>
{% endblock %}
