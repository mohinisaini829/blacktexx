<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="StudioSolid\AdvancedSliderElements\Core\Framework\Adapter\Twig\Extension\TwigExtensions">
            <tag name="twig.extension"/>
        </service>

        <service id="StudioSolid\AdvancedSliderElements\Core\Content\Cms\DataResolver\Element\ContentSliderCmsElementResolver">
            <argument type="service" id="Shopware\Core\Framework\Util\HtmlSanitizer"/>
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="StudioSolid\AdvancedSliderElements\Core\Content\Media\Subscriber\MediaSubscriber">
            <argument type="service" id="cms_slot.repository"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="StudioSolid\AdvancedSliderElements\Core\Content\Cms\ScheduledTask\UpdateScheduledSlidesTask">
            <tag name="shopware.scheduled.task" />
        </service>

        <service id="StudioSolid\AdvancedSliderElements\Core\Content\Cms\ScheduledTask\UpdateScheduledSlidesTaskHandler">
            <argument type="service" id="scheduled_task.repository" />
            <argument type="service" id="logger"/>
            <argument type="service" id="cms_slot.repository" />
            <argument type="service" id="cms_slot_translation.repository" />
            <argument type="service" id="category_translation.repository" />

            <tag name="messenger.message_handler" />
        </service>
    </services>
</container>
