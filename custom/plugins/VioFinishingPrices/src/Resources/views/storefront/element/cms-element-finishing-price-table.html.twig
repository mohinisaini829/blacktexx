{% block element_finishing_price_table %}
    {% set config = element.fieldConfig.elements %}
    {# @var finishingPriceTables \Vio\FinishingPrices\Content\FinishingPriceTableCollection #}
    {% set finishingPriceTables = element.data %}
    <!-- {{ dump(finishingPriceTables.count) }} -->
    {% if finishingPriceTables and finishingPriceTables.count > 0 %}
        <div class="cms-element-{{ element.type }}" data-finishing-price-tables="true">
            <select class="finishing-price-tables-select custom-select" aria-label="{{ 'vioFinishingPrices.selectLabel'|trans|sw_sanitize }}">
                {% for finishingPriceTable in finishingPriceTables %}
                    <option value="{{ finishingPriceTable.id }}">{{ finishingPriceTable.translated.name }}</option>
                {% endfor %}
            </select>
            <div class="card">
                <div class="card-body" id="finishing-price-table">
                    {% for finishingPriceTable in finishingPriceTables %}
                        <div class="finishing-price-table-text{% if loop.first %} is-active{% endif %}" id="finishing-price-table-{{ finishingPriceTable.id }}">
                            {{ finishingPriceTable.translated.text|raw }}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}

    {# Brand Catalog Section - After finishing price table #}
    {% if page.product and page.product.manufacturer %}
        {% set manufacturerName = page.product.manufacturer.translated.name|trim %}
        {% set brandData = getBrandByName(manufacturerName) %}

        {% if brandData and brandData.catalog_pdf_path %}
            <div class="container-fluid mt-5 mb-5">
                 <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">{{ brandData.name }} {{ "Catalog"|trans }}</h4>
                 </div>
                <div class="brand-catalog-section" id="brand_catalog">
                    <div class="card shadow">
                       
                        <div class="card-body p-0">
                            <div class="catalog-viewer-container" style="position: relative; width: 100%; padding-bottom: 75%; overflow: hidden; background: #f5f5f5;">
                                <iframe src="{{ brandData.catalog_pdf_path }}" 
                                        style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none;"
                                        frameborder="0"
                                        allowfullscreen>
                                </iframe>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    {% endif %}
{% endblock %}
