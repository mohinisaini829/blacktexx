<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="https://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Vio\FinishingPrices\Content\FinishingPriceTableDefinition">
            <tag name="shopware.entity.definition"/>
        </service>

        <service id="Vio\FinishingPrices\Content\Aggregate\FinishingPriceTableTranslation\FinishingPriceTableTranslationDefinition">
            <tag name="shopware.entity.definition"/>
        </service>

        <service id="Vio\FinishingPrices\Resolver\FinishingPriceTableResolver">
            <argument id="finishing_price_table.repository" type="service"/>
            <tag name="shopware.cms.data_resolver"/>
        </service>

    </services>
</container>
